# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Google Drive (Service Account — preferred for local) ─────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=

# ─── Google Drive (OAuth2 — optional alternative) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
GOOGLE_REFRESH_TOKEN=

# ─── Drive Folders ────────────────────────────────────────────────────────────
GDRIVE_FOLDER_ID=                  # LuxRig_Brain root folder ID
GDRIVE_OPS_FILE_ID=                # optional: CURRENT_OPS.md file ID
GSHEETS_PIPELINE_TRACKER_ID=       # optional: pipeline sync Google Sheet

# ─── Local LLM ────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2
LM_STUDIO_BASE_URL=http://localhost:1234
LM_STUDIO_DEFAULT_MODEL=local-model
