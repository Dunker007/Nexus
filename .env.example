# ============================================
# Nexus-PiecesOS Environment Configuration
# Copy this file to .env.local and fill in values
# ============================================

# --- App Mode ---
NEXT_PUBLIC_IS_WEB="false"

# --- Bridge / Backend ---
# Session signing key (auto-generated on first boot if not set)
# SESSION_SECRET="generate-a-random-64-char-hex-string"

# AES-256 encryption key for token storage (auto-generated on first boot if not set)
# TOKEN_ENCRYPTION_KEY="generate-a-random-64-char-hex-string"

# API key for authenticating bridge requests
# API_KEY="generate-a-random-api-key"

# --- LLM Providers ---
# LM Studio (OpenAI-compatible local LLM)
LMSTUDIO_URL="http://127.0.0.1:1234"

# Ollama
OLLAMA_URL="http://127.0.0.1:11434"

# --- Pieces OS ---
# Pieces OS runs locally; port is auto-detected (1000 on Windows, 39300 on Linux)
# No configuration needed unless running on a non-standard port.

# --- Google APIs (optional, for Drive/Auth) ---
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI=""

# --- Database ---
# SQLite path is auto-resolved from bridge/prisma/dev.db
# DATABASE_URL="file:./prisma/dev.db"
